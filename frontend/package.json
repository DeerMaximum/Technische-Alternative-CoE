{
  "name": "web-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --base-href=/ta-coe-hass/ && tsc --project tsconfig.panel.json",
    "build:panel": "tsc --project tsconfig.panel.json",
    "watch": "ng build --watch --base-href=/ta-coe-hass/ --configuration development",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "custom-card-helpers": "2.0.0",
    "ng-select2-component": "^17.2.9",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "angular-eslint": "21.3.0",
    "eslint": "^10.2.0",
    "@eslint/js": "^10.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.58.0"
  }
}
